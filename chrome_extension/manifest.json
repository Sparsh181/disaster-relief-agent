{
  "manifest_version": 3,
  "name": "Disaster Relief Agent",
  "version": "1.0.0",
  "description": "Real-time global disaster alerts near your location",
  "permissions": ["geolocation", "notifications", "storage", "alarms"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_badge_text": ""
  },
  "background": {
    "service_worker": "background.js"
  }
}
